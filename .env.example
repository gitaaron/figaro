# ---------------------------------------------------------------------------
# Figaro configuration
# Copy this file to ".env" and fill in the key(s) for the provider(s) you use.
# You only need a key for the provider(s) you actually select in the app.
# With NO keys set, Figaro still runs using the built-in "mock" provider so
# you can explore the whole flow before adding credentials.
# ---------------------------------------------------------------------------

# Server port
PORT=3000

# Default LLM provider when the client doesn't specify one.
# One of: claude | openai | gemini | mock
DEFAULT_PROVIDER=mock

# --- Anthropic (Claude) -----------------------------------------------------
ANTHROPIC_API_KEY=
# Model string. See https://platform.claude.com/docs/en/about-claude/models/overview
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI (ChatGPT) -------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Google (Gemini) --------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Text-to-speech for background-playable audio lectures
# ---------------------------------------------------------------------------
# TTS_PROVIDER selects which engine to use. Options:
#   gtts       — Free, no API key needed. Requires Python + gTTS installed:
#                  pip install gtts
#   openai     — Requires OPENAI_API_KEY above.
#   elevenlabs — Higher quality. Requires ELEVENLABS_API_KEY below.
TTS_PROVIDER=gtts

# --- OpenAI TTS (only needed when TTS_PROVIDER=openai) ---------------------
# OPENAI_TTS_MODEL=tts-1          # or tts-1-hd for higher quality
# OPENAI_TTS_VOICE=alloy          # alloy | echo | fable | onyx | nova | shimmer

# --- ElevenLabs (only needed when TTS_PROVIDER=elevenlabs) -----------------
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # default: "Sarah"
# ELEVENLABS_MODEL=eleven_turbo_v2
