# ---------------------------------------------------------------------------
# Figaro configuration
# Copy this file to ".env" and fill in the key(s) for the provider(s) you use.
# You only need a key for the provider(s) you actually select in the app.
# With NO keys set, Figaro still runs using the built-in "mock" provider so
# you can explore the whole flow before adding credentials.
# ---------------------------------------------------------------------------

# Server port
PORT=3000

# Default LLM provider when the client doesn't specify one.
# One of: claude | openai | gemini | mock
DEFAULT_PROVIDER=mock

# --- Anthropic (Claude) -----------------------------------------------------
ANTHROPIC_API_KEY=
# Model string. See https://platform.claude.com/docs/en/about-claude/models/overview
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI (ChatGPT) -------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Google (Gemini) --------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
